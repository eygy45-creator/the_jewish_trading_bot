# Server-side only (Next.js Route Handler). Set in Vercel → Settings → Environment Variables.
# Do not prefix with NEXT_PUBLIC_ — never expose API_TOKEN to the browser.

# Base URL of the existing FastAPI deployment (no trailing slash), e.g. https://your-api.vercel.app
TJTB_API_BASE_URL=

# Same bearer token the FastAPI app expects (Authorization: Bearer ...)
API_TOKEN=
