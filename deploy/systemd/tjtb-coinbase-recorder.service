[Unit]
Description=TJTB Coinbase Advanced Trade NDJSON recorder (paper / public WS)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/the_jewish_trading_bot/the_jewish_trading_bot
ExecStart=/home/ubuntu/the_jewish_trading_bot/the_jewish_trading_bot/venv/bin/python3 scripts/recorder/coinbase_recorder.py
Restart=on-failure
RestartSec=5
StartLimitIntervalSec=300
StartLimitBurst=30

StandardOutput=append:/home/ubuntu/the_jewish_trading_bot/the_jewish_trading_bot/logs/coinbase_recorder.systemd.log
StandardError=append:/home/ubuntu/the_jewish_trading_bot/the_jewish_trading_bot/logs/coinbase_recorder.systemd.log
SyslogIdentifier=tjtb-coinbase-recorder

[Install]
WantedBy=multi-user.target
